<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The Barber Pole Denver</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, Helvetica, sans-serif;
}

body{
    background:#f5f5f5;
    color:#222;
    line-height:1.6;
}

/* Header */
header{
    background:#111;
    color:white;
    text-align:center;
    padding:100px 20px;
}

header h1{
    font-size:4rem;
    letter-spacing:3px;
}

header p{
    font-size:1.3rem;
    margin-top:15px;
    color:#d1d1d1;
}

.btn{
    display:inline-block;
    margin-top:25px;
    padding:14px 28px;
    background:#b22222;
    color:white;
    text-decoration:none;
    border-radius:4px;
    font-weight:bold;
    transition:.3s;
}

.btn:hover{
    background:#8b1a1a;
}

/* Sections */
section{
    max-width:1200px;
    margin:auto;
    padding:80px 20px;
}

.section-title{
    text-align:center;
    margin-bottom:40px;
}

.section-title h2{
    font-size:2.5rem;
    color:#111;
}

.about{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:40px;
    align-items:center;
}

.about img{
    width:100%;
    border-radius:10px;
}

.services{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:25px;
}

.card{
    background:white;
    padding:30px;
    border-radius:10px;
    box-shadow:0 5px 15px rgba(0,0,0,.1);
    text-align:center;
}

.card h3{
    margin-bottom:10px;
    color:#b22222;
}

/* Contact */
.contact{
    background:#111;
    color:white;
    text-align:center;
    border-radius:10px;
    padding:60px 20px;
}

.contact p{
    margin:10px 0;
}

/* Footer */
footer{
    text-align:center;
    background:#000;
    color:white;
    padding:25px;
}

@media(max-width:768px){
    .about{
        grid-template-columns:1fr;
    }

    header h1{
        font-size:2.5rem;
    }
}
</style>
</head>

<body>

<header>
    <h1>The Barber Pole Denver</h1>
    <p>Traditional Craftsmanship. Modern Style.</p>
    <a href="#contact" class="btn">Book Your Visit</a>
</header>

<section>
    <div class="section-title">
        <h2>About Us</h2>
    </div>

    <div class="about">
        <div>
            <h3>Denver's Neighborhood Barbershop</h3>
            <p>
                The Barber Pole is a classic-style barbershop offering
                traditional craftsmanship with a modern edge. We specialize
                in precision haircuts and straight-razor shaves, combining
                old-school barbering techniques with contemporary styles.
            </p>

            <br>

            <p>
                Located on East Colfax Avenue in Denver's Congress Park
                neighborhood, we proudly serve locals, neighbors, and
                visitors alike. Every service is delivered with quality,
                consistency, and attention to detail.
            </p>
        </div>

        <div>
            <img src="https://images.unsplash.com/photo-1621605815971-fbc98d665033?auto=format&fit=crop&w=1200&q=80"
            alt="Barbershop">
        </div>
    </div>
</section>

<section>
    <div class="section-title">
        <h2>Our Services</h2>
    </div>

    <div class="services">

        <div class="card">
            <h3>Precision Haircuts</h3>
            <p>
                Clean, tailored cuts designed to fit your style,
                profession, and personality.
            </p>
        </div>

        <div class="card">
            <h3>Straight-Razor Shaves</h3>
            <p>
                Experience the timeless tradition of a professional
                hot-towel straight-razor shave.
            </p>
        </div>

        <div class="card">
            <h3>Modern Styling</h3>
            <p>
                Contemporary fades, textured cuts, and personalized
                grooming services.
            </p>
        </div>

    </div>
</section>

<section id="contact">
    <div class="contact">
        <h2>Visit The Barber Pole</h2>

        <p><strong>Address:</strong></p>
        <p>2928 East Colfax Avenue</p>
        <p>Denver, CO</p>

        <br>

        <p><strong>Hours:</strong></p>
        <p>Monday - Saturday: 9:00 AM - 6:00 PM</p>
        <p>Sunday: Closed</p>

        <br>

        <p>
            Walk-ins welcome. Appointments recommended.
        </p>
    </div>
</section>

<footer>
    <p>© 2026 The Barber Pole Denver. All Rights Reserved.</p>
</footer>

</body>
</html>